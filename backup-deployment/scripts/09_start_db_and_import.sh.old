!/bin/bash

# Script zum Starten der Datenbank-Container und Import des SQL-Dumps
# Startet db und databasedump Container und importiert nextcloud_dump.sql

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$SCRIPT_DIR/lib/functions.sh"
source "$SCRIPT_DIR/config.sh"

# Konfiguration
COMPOSE_PATH="$DOMAIN_REPLACE_PATH/ggg"
SQL_FILE="/root/nextcloud_dump.sql"
DB_CONTAINER="nextcloud-mariadb"
DUMP_CONTAINER="databasedump"
DB_NAME="nextcloud"
DB_USER="nextcloud"
DB_PASSWORD="nextcloud"
DB_ROOT_PASSWORD="ren.chel"

# ===========================================
# SCHRITT 9: DATENBANK STARTEN UND IMPORT
# ===========================================

log_step "9/9: Datenbank-Container starten und SQL-Import"

log_info "Konfiguration:"
log_info "  Docker-Compose-Pfad: $COMPOSE_PATH"
log_info "  SQL-Datei: $SQL_FILE"
log_info "  DB-Container: $DB_CONTAINER"
log_info "  Dump-Container: $DUMP_CONTAINER"
log_info "  Datenbank: $DB_NAME"
echo ""

# Voraussetzungen prüfen
log_info "Prüfe Voraussetzungen..."

# Docker-Compose-Datei vorhanden?
if ! run_ssh_command "test -f $COMPOSE_PATH/docker-compose.yaml"; then
    log_error "docker-compose.yaml nicht gefunden: $COMPOSE_PATH/docker-compose.yaml"
    exit 1
fi

# SQL-Datei vorhanden?
if ! run_ssh_command "test -f $SQL_FILE"; then
    log_error "SQL-Datei nicht gefunden: $SQL_FILE"
    log_info "Verfügbare Dateien in /root:"
    run_ssh_command "ls -la /root/*.sql* 2>/dev/null || echo 'Keine SQL-Dateien gefunden'"
    exit 1
fi

# Docker-Image 'databasedump' vorhanden?
if ! run_ssh_command "docker images | grep -q '^databasedump'"; then
    log_error "Docker-Image 'databasedump' nicht gefunden"
    log_info "Verfügbare Images:"
    run_ssh_command "docker images"
    exit 1
fi

log_success "Alle Voraussetzungen erfüllt"

# Container stoppen (falls laufend)
log_info "Stoppe eventuell laufende Container..."
run_ssh_command "
cd $COMPOSE_PATH && 
docker-compose stop $DB_CONTAINER $DUMP_CONTAINER 2>/dev/null || true
"

# SQL-Datei in dump-Verzeichnis kopieren
log_info "Bereite SQL-Import vor..."
run_ssh_command "
mkdir -p $COMPOSE_PATH/dump &&
cp $SQL_FILE $COMPOSE_PATH/dump/ &&
chmod 644 $COMPOSE_PATH/dump/nextcloud_dump.sql &&
ls -la $COMPOSE_PATH/dump/
"

# Container starten
log_info "Starte Datenbank-Container..."

START_COMMAND="
cd $COMPOSE_PATH &&
docker-compose up -d $DB_CONTAINER &&
echo 'Warte auf Datenbank-Start...' &&
sleep 10
"

if ! run_ssh_command "$START_COMMAND"; then
    log_error "Fehler beim Starten des Datenbank-Containers"
    exit 1
fi

# Warten bis MariaDB bereit ist
log_info "Warte auf MariaDB-Bereitschaft..."

WAIT_COMMAND="
cd $COMPOSE_PATH &&
for i in {1..30}; do
    if docker-compose exec -T $DB_CONTAINER mysql -u root -p'$DB_ROOT_PASSWORD' -e 'SELECT 1' >/dev/null 2>&1; then
        echo 'MariaDB ist bereit!'
        break
    fi
    echo 'Warte auf MariaDB... (\$i/30)'
    sleep 2
done
"

if ! run_ssh_command "$WAIT_COMMAND"; then
    log_error "MariaDB wurde nicht rechtzeitig bereit"
    
    # Logs zur Fehlerdiagnose
    log_info "Container-Logs zur Diagnose:"
    run_ssh_command "cd $COMPOSE_PATH && docker-compose logs $DB_CONTAINER | tail -20"
    exit 1
fi

log_success "MariaDB ist bereit"

# Databasedump-Container starten
log_info "Starte Databasedump-Container..."

if ! run_ssh_command "cd $COMPOSE_PATH && docker-compose up -d $DUMP_CONTAINER"; then
    log_error "Fehler beim Starten des Databasedump-Containers"
    exit 1
fi

log_success "Beide Container sind gestartet"

# Container-Status prüfen
log_info "Container-Status:"
run_ssh_command "cd $COMPOSE_PATH && docker-compose ps | grep -E '(nextcloud-mariadb|databasedump)'"

# SQL-Import durchführen
log_info "Starte SQL-Import..."

# Variante 1: Import über DB-Container
IMPORT_COMMAND="
cd $COMPOSE_PATH &&
echo 'Importiere SQL-Dump in Datenbank...' &&
docker-compose exec -T $DB_CONTAINER mysql -u root -p'$DB_ROOT_PASSWORD' $DB_NAME < dump/nextcloud_dump.sql
"

log_info "Führe SQL-Import durch (dies kann einige Minuten dauern)..."

if run_ssh_command "$IMPORT_COMMAND"; then
    log_success "SQL-Import erfolgreich abgeschlossen!"
    
    # Import verifizieren
    log_info "Verifiziere Import..."
    VERIFY_COMMAND="
    cd $COMPOSE_PATH &&
    docker-compose exec -T $DB_CONTAINER mysql -u root -p'$DB_ROOT_PASSWORD' $DB_NAME -e 'SHOW TABLES;' | wc -l
    "
    
    TABLE_COUNT=$(run_ssh_command "$VERIFY_COMMAND" | tail -1)
    log_success "Anzahl Tabellen in der Datenbank: $TABLE_COUNT"
    
else
    log_error "Fehler beim SQL-Import!"
    
    # Alternative: Import über databasedump-Container versuchen
    log_info "Versuche Import über databasedump-Container..."
    
    ALT_IMPORT_COMMAND="
    cd $COMPOSE_PATH &&
    docker-compose exec -T $DUMP_CONTAINER mysql -h $DB_CONTAINER -u root -p'$DB_ROOT_PASSWORD' $DB_NAME < /dump/nextcloud_dump.sql
    "
    
    if run_ssh_command "$ALT_IMPORT_COMMAND"; then
        log_success "SQL-Import über databasedump-Container erfolgreich!"
    else
        log_error "Auch alternativer Import fehlgeschlagen"
        
        # Fehlerdiagnose
        log_info "Fehlerdiagnose:"
        log_info "1. Container-Logs:"
        run_ssh_command "cd $COMPOSE_PATH && docker-compose logs $DB_CONTAINER | tail -10"
        
        log_info "2. Datei-Zugriff prüfen:"
        run_ssh_command "ls -la $COMPOSE_PATH/dump/"
        
        log_info "3. Datenbank-Verbindung testen:"
        run_ssh_command "cd $COMPOSE_PATH && docker-compose exec -T $DB_CONTAINER mysql -u root -p'$DB_ROOT_PASSWORD' -e 'SHOW DATABASES;'"
        
        exit 1
    fi
fi

echo ""
log_success "=========================================="
log_success "   DATENBANK-IMPORT ERFOLGREICH!        "
log_success "=========================================="

echo ""
log_info "📋 ZUSAMMENFASSUNG:"
log_info "════════════════════════════════════════"
log_success "  ✅ MariaDB-Container gestartet"
log_success "  ✅ Databasedump-Container gestartet"
log_success "  ✅ SQL-Import abgeschlossen"

echo ""
log_info "🐳 CONTAINER-STATUS:"
log_info "════════════════════════════════════════"
run_ssh_command "cd $COMPOSE_PATH && docker-compose ps"

echo ""
log_info "🗄️ DATENBANK-INFO:"
log_info "════════════════════════════════════════"
run_ssh_command "
cd $COMPOSE_PATH &&
echo 'Datenbank-Größe:' &&
docker-compose exec -T $DB_CONTAINER mysql -u root -p'$DB_ROOT_PASSWORD' -e \"
SELECT 
    table_schema AS 'Database',
    ROUND(SUM(data_length + index_length) / 1024 / 1024, 2) AS 'Size (MB)'
FROM information_schema.tables 
WHERE table_schema = '$DB_NAME'
GROUP BY table_schema;
\" &&
echo '' &&
echo 'Anzahl Tabellen:' &&
docker-compose exec -T $DB_CONTAINER mysql -u root -p'$DB_ROOT_PASSWORD' $DB_NAME -e 'SHOW TABLES;' | wc -l
"

echo ""
log_info "🔧 NÄCHSTE SCHRITTE:"
log_info "════════════════════════════════════════"
log_info "  1. Weitere Container starten:"
log_info "     cd $COMPOSE_PATH"
log_info "     docker-compose up -d"
log_info ""
log_info "  2. Nextcloud-Logs prüfen:"
log_info "     docker-compose logs -f app"
log_info ""
log_info "  3. Nextcloud aufrufen:"
log_info "     https://$NEW_DOMAIN"

echo ""
log_success "Datenbank-Import abgeschlossen! 🗄️"
